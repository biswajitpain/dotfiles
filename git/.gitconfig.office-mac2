[user]
    name = Biswajit Pain
    email = biswajit.pain@outlook.com
    signingkey = ~/.ssh/id_office-mac2.pub
[core]
    environment = LANG=en_US
    editor = vim
    excludesfile = ~/.gitignore_global
[color]
    ui = auto
[pull]
    rebase = true
[init]
    defaultBranch = main
[commit]
    template = ~/.gitmessage
    gpgsign = true
[tag]
    gpgsign = true
[gpg]
    format = ssh
[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers