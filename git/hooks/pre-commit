#!/usr/bin/env bash
# Pre-commit hook: block secrets from being committed.
# Installed globally via core.hooksPath by install.sh.

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FAILED=0

staged_files() {
    # Exclude the hooks directory itself вЂ” pattern strings inside hooks are not secrets
    git diff --cached --name-only --diff-filter=ACM | grep -v '^git/hooks/'
}

# в”Ђв”Ђ 1. Block known secret file names в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SECRET_FILE_PATTERNS=(
    '\.env$'
    '\.env\.'
    'azure-subscriptions\.env$'
    'credentials\.json$'
    'secrets\.json$'
    'secret\.yaml$'
    'secret\.yml$'
    '\.pem$'
    '\.p12$'
    '\.pfx$'
    '\.keystore$'
)

for file in $(staged_files); do
    for pattern in "${SECRET_FILE_PATTERNS[@]}"; do
        if echo "$file" | grep -qE "$pattern"; then
            # Allow template files
            if echo "$file" | grep -qE '\.template$'; then
                continue
            fi
            echo -e "${RED}[SECRET BLOCK]${NC} Refusing to commit secret file: $file"
            FAILED=1
        fi
    done
done

# в”Ђв”Ђ 2. Block private SSH / TLS key content в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PRIVATE_KEY_PATTERN='-----BEGIN .* PRIVATE KEY-----'

for file in $(staged_files); do
    if git diff --cached -- "$file" | grep -qE -- "$PRIVATE_KEY_PATTERN"; then
        echo -e "${RED}[SECRET BLOCK]${NC} Private key content detected in: $file"
        FAILED=1
    fi
done

# в”Ђв”Ђ 3. Block high-entropy secret patterns в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Matches common token/key assignment patterns:
#   API_KEY="abc123..."   TOKEN=xxx   SECRET=xxx   PASSWORD=xxx
SECRET_CONTENT_PATTERN='(API_KEY|API_SECRET|ACCESS_TOKEN|SECRET_KEY|AUTH_TOKEN|PRIVATE_KEY|PASSWORD|PASSWD|AZ_SUB_[A-Z_]+=")[^"]{8,}"'

for file in $(staged_files); do
    if git diff --cached -- "$file" | grep -qE "$SECRET_CONTENT_PATTERN"; then
        echo -e "${RED}[SECRET BLOCK]${NC} Possible secret value detected in: $file"
        echo -e "${YELLOW}  If this is a false positive, use: git commit --no-verify${NC}"
        FAILED=1
    fi
done

# в”Ђв”Ђ 4. Block SSH private key files (files without .pub extension) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
for file in $(staged_files); do
    if echo "$file" | grep -qE '^(ssh/|\.ssh/|id_rsa|id_ed25519|id_ecdsa)' && \
       ! echo "$file" | grep -qE '\.pub$|config$|known_hosts$|authorized_keys$'; then
        echo -e "${RED}[SECRET BLOCK]${NC} Possible SSH private key file: $file"
        FAILED=1
    fi
done

# в”Ђв”Ђ 5. Warn on .env.template files that contain real-looking values в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
UUID_PATTERN='[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}'

for file in $(staged_files); do
    if echo "$file" | grep -qE '\.template$'; then
        if git diff --cached -- "$file" | grep -qE "$UUID_PATTERN"; then
            echo -e "${YELLOW}[SECRET WARN]${NC} Real-looking UUID found in template: $file"
            echo -e "${YELLOW}  Templates should use placeholder values, not real IDs.${NC}"
            FAILED=1
        fi
    fi
done

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo -e "${RED}Commit blocked.${NC} Remove secrets before committing."
    echo "To skip this check (only if you're sure): git commit --no-verify"
    exit 1
fi

exit 0
